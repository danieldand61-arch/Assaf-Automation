# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ElevenLabs (for video dubbing)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Kling AI (for video generation)
KLING_API_KEY=your_kling_api_key_here

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=https://app.joyo.marketing

# Admin Dashboard
ADMIN_EMAILS=admin@example.com
CORS_ORIGINS=https://yourfrontend.com,http://localhost:5173

# JWT Secret (for authentication)
JWT_SECRET=your_jwt_secret_key_here

# Social Media API Keys (optional)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Google Ads (optional)
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token

# Meta Pixel + Conversions API
# Frontend (build-time): VITE_META_PIXEL_ID — must be set in the frontend's env (Railway/Vercel)
VITE_META_PIXEL_ID=your_meta_pixel_id
# Backend (runtime):
META_PIXEL_ID=your_meta_pixel_id
META_CAPI_ACCESS_TOKEN=your_meta_capi_access_token
# Optional, only during testing — remove in production
META_TEST_EVENT_CODE=
